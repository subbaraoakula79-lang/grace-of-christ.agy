# ========================
# ENVIRONMENT VARIABLES
# ========================
# Copy this file to .env and fill in your values.

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database (Neon PostgreSQL) ──────────────────────────
# Get both URLs from your Neon dashboard → Connection Details
# Pooled connection (for app runtime — uses PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct connection (for Prisma migrations)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── JWT Authentication ───────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── 2FA (TOTP) ───────────────────────────────────────────
TOTP_ISSUER=GraceOfChrist

# ── Mock Payment (dev) / Razorpay (prod) ─────────────────
PAYMENT_MODE=mock
# PAYMENT_MODE=razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Mock Email (dev) / SMTP (prod) ───────────────────────
EMAIL_MODE=mock
# EMAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Grace of Christ <noreply@graceofchrist.org>"

# ── Firebase Storage (image uploads) ─────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ── Church Info ──────────────────────────────────────────
CHURCH_NAME=Grace of Christ (GOC)
CHURCH_LOCATION=Yetimoga, Kakinada, Andhra Pradesh, India
CHURCH_PASTOR=K. John Prasad
