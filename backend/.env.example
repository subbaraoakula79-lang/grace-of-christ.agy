# ========================
# ENVIRONMENT VARIABLES
# ========================
# Copy this file to .env and fill in your values.
# Run `node scripts/setup-env.js` to auto-generate secrets.

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ── Database (SQLite) ────────────
DATABASE_URL="file:./dev.db"

# ── JWT Authentication ───────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── 2FA (TOTP) ───────────────────────────────────────────
TOTP_ISSUER=GraceOfChrist

# ── Mock Payment (dev) / Razorpay (prod) ─────────────────
PAYMENT_MODE=mock
# PAYMENT_MODE=razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Mock Email (dev) / SMTP (prod) ───────────────────────
EMAIL_MODE=mock
# EMAIL_MODE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Grace of Christ <noreply@graceofchrist.org>"
# Or use Resend:
# RESEND_API_KEY=re_your_resend_api_key

# ── Cloudinary (image uploads) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Church Info ──────────────────────────────────────────
CHURCH_NAME=Grace of Christ (GOC)
CHURCH_LOCATION=Yetimoga, Kakinada, Andhra Pradesh, India
CHURCH_PASTOR=K. John Prasad
